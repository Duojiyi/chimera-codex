# Windows shell scripts require CRLF for cmd.exe label parsing
# (LF-only .bat files break `goto label` at runtime).
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

*.sh text eol=lf
.github/workflows/*.yml text eol=lf

# Generated branding must stay LF to match scripts/generate-branding.ps1 -Check.
crates/codex-plus-core/src/branding.rs text eol=lf
apps/codex-plus-manager/src/branding.generated.ts text eol=lf
# Preserve the original Snow Skin asset line endings for byte-exact bundling.
assets/inject/upstream/snow-skin/*.js text eol=lf
assets/inject/upstream/snow-skin/*.css text eol=lf
